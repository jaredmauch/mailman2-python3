"""Primary start-up and shutdown script for Mailman's qrunner daemon.

This script starts, stops, and restarts the main Mailman queue runners, making
sure that the various long-running qrunners are still alive and kicking.  It
does this by forking and exec'ing the qrunners and waiting on their pids.
When it detects a subprocess has exited, it may restart it.

The qrunners respond to SIGINT, SIGTERM, and SIGHUP.  SIGINT and SIGTERM both
cause the qrunners to exit cleanly, but the master will only restart qrunners
that have exited due to a SIGINT.  SIGHUP causes the master and the qrunners
to close their log files, and reopen then upon the next printed message.

The master also responds to SIGINT, SIGTERM, and SIGHUP, which it simply
passes on to the qrunners (note that the master will close and reopen its own
log files on receipt of a SIGHUP).  The master also leaves its own process id
in the file data/master-qrunner.pid but you normally don't need to use this
pid directly.  The `start', `stop', `restart', and `reopen' commands handle
everything for you.

Usage: %(PROGRAM)s [options] [ start | stop | restart | reopen ]

Options:

    -n/--no-restart
        Don't restart the qrunners when they exit because of an error or a
        SIGINT.  They are never restarted if they exit in response to a
        SIGTERM.  Use this only for debugging.  Only useful if the `start'
        command is given.

    -u/--run-as-user
        Normally, this script will refuse to run if the user id and group id
        are not set to the `mailman' user and group (as defined when you
        configured Mailman).  If run as root, this script will change to this
        user and group before the check is made.

        This can be inconvenient for testing and debugging purposes, so the -u
        flag means that the step that sets and checks the uid/gid is skipped,
        and the program is run as the current user and group.  This flag is
        not recommended for normal production environments.

        Note though, that if you run with -u and are not in the mailman group,
        you may have permission problems, such as begin unable to delete a
        list's archives through the web.  Tough luck!

    -s/--stale-lock-cleanup
        If mailmanctl finds an existing master lock, it will normally exit
        with an error message.  With this option, mailmanctl will perform an
        extra level of checking.  If a process matching the host/pid described
        in the lock file is running, mailmanctl will still exit, but if no
        matching process is found, mailmanctl will remove the apparently stale
        lock and make another attempt to claim the master lock.

    -q/--quiet
        Don't print status messages.  Error messages are still printed to
        standard error.

    -h/--help
        Print this message and exit.

Commands:

    start   - Start the master daemon and all qrunners.  Prints a message and
              exits if the master daemon is already running.

    stop    - Stops the master daemon and all qrunners.  After stopping, no
              more messages will be processed.

    restart - Restarts the qrunners, but not the master process.  Use this
              whenever you upgrade or update Mailman so that the qrunners will
              use the newly installed code.

    reopen  - This will close all log files, causing them to be re-opened the
              next time a message is written to them
"""

import sys
import os
import time
import getopt
import signal
import errno
import pwd
import grp
import socket

import paths
from Mailman import mm_cfg
from Mailman import Utils
from Mailman import LockFile
from Mailman import Errors
from Mailman.MailList import MailList
from Mailman.i18n import C_
from Mailman.Logging.Syslog import syslog
from Mailman.Logging.Utils import LogStdErr

PROGRAM = sys.argv[0]
COMMASPACE = ', '
DOT = '.'

# Locking contantsa
LOCKFILE = os.path.join(mm_cfg.LOCK_DIR, mm_cfg.MASTER_LOCK_FILE)
# Since we wake up once per day and refresh the lock, the LOCK_LIFETIME
# needn't be (much) longer than SNOOZE.  We pad it 6 hours just to be safe.
LOCK_LIFETIME = mm_cfg.days(1) + mm_cfg.hours(6)
SNOOZE = mm_cfg.days(1)
MAX_RESTARTS = 10

LogStdErr('error', 'mailmanctl', manual_reprime=0)

# Stash this here for convenience.
class Status:
    pass

def makeabs(path):
    if path[0] != '/':
        path = os.path.join(mm_cfg.PREFIX, path)
    return path

def kill_watcher(sig=signal.SIGTERM):
    # Kill any existing watching daemon
    try:
        with open(mm_cfg.PIDFILE) as fp:
            pid = int(fp.read().strip())
        os.kill(pid, sig)
        # Give the process time to die
        time.sleep(1)
    except (IOError, ValueError) as e:
        if e.errno != errno.ENOENT:
            print(str(e), file=sys.stderr)
    except OSError as e:
        if e.errno != errno.ESRCH:
            print(str(e), file=sys.stderr)

def unlock_and_exit(status=0):
    try:
        os.unlink(mm_cfg.PIDFILE)
    except OSError as e:
        if e.errno != errno.ENOENT:
            print(str(e), file=sys.stderr)
    sys.exit(status)

def write_pidfile():
    # First try to lock the pid file.  If we can't, then another master is
    # already running.  Note that when the file is written, it is neither group
    # or other readable.
    try:
        with open(mm_cfg.PIDFILE, 'x') as fp:
            fp.write(f'{os.getpid()}\n{socket.getfqdn()}\n')
    except FileExistsError:
        # The pid file already exists, so another master must be running
        print(C_('Master qrunner daemon already running with pid: %s'), file=sys.stderr)
        sys.exit(1)
    except OSError as e:
        print(e, file=sys.stderr)
        sys.exit(1)

def get_lock_data():
    # See if we can get the host name from DNS
    fqdn = socket.getfqdn()
    try:
        with open(mm_cfg.PIDFILE) as fp:
            parts = fp.read().split('\n')
        if len(parts) != 2:
            return None, None, None
        pid = int(parts[0])
        hostname = parts[1]
        if hostname != fqdn:
            return pid, hostname, -1
        # Is the process still alive?
        try:
            os.kill(pid, 0)
            return pid, hostname, 1
        except OSError as e:
            if e.errno != errno.ESRCH:
                raise
            return pid, hostname, 0
    except (IOError, ValueError) as e:
        if e.errno != errno.ENOENT:
            print(str(e), file=sys.stderr)
        return None, None, None

def acquire_lock_or_exit():
    """Acquire the master lock or exit with an error message."""
    try:
        lock = LockFile.LockFile(LOCKFILE, lifetime=LOCK_LIFETIME)
        lock.lock()
    except LockFile.LockError as e:
        print(str(e), file=sys.stderr)
        sys.exit(1)
    return lock

def start_runner(qrname, qrclass, status):
    """Start a queue runner and return its pid."""
    try:
        pid = os.fork()
    except OSError as e:
        print(f'fork() failed: {e}', file=sys.stderr)
        return None
    if pid == 0:
        # Child process
        try:
            # Close all file descriptors except stdin, stdout, and stderr
            for fd in range(3, 256):
                try:
                    os.close(fd)
                except OSError:
                    pass
            # Start the queue runner
            qr = qrclass()
            qr.run()
        except Exception as e:
            print(f'Queue runner {qrname} failed: {e}', file=sys.stderr)
            sys.exit(1)
    # Parent process
    status.runners[qrname] = pid
    return pid

def start_all_runners():
    kids = {}
    for qrname, count in mm_cfg.QRUNNERS:
        for slice in range(count):
            # queue runner name, slice, numslices, restart count
            info = (qrname, slice, count, 0)
            pid = start_runner(qrname, slice, count)
            kids[pid] = info
    return kids

def check_for_site_list():
    sitelistname = mm_cfg.MAILMAN_SITE_LIST
    try:
        sitelist = MailList(sitelistname, lock=0)
    except Errors.MMUnknownListError:
        print(C_('Site list is missing: %s') % sitelistname, file=sys.stderr)
        syslog('error', 'Site list is missing: %s', mm_cfg.MAILMAN_SITE_LIST)
        sys.exit(1)

def check_privs():
    # If we're running as root (uid == 0), then seteuid to Mailman's uid.  If we
    # can't, exit with message.
    try:
        running_uid = os.geteuid()
        if running_uid != 0:
            if running_uid != mm_cfg.UID:
                name = mm_cfg.USERNAME
                usage(1, C_('Run this program as root or as the %s user, or use -u.') % name)
    except AttributeError as e:
        # Ignore if we don't have geteuid
        pass

def main():
    """Main entry point."""
    try:
        opts, args = getopt.getopt(sys.argv[1:], 'hnusq',
                                  ['help', 'no-restart', 'run-as-user',
                                   'stale-lock-cleanup', 'quiet'])
    except getopt.error as e:
        print(str(e), file=sys.stderr)
        print(__doc__ % {'PROGRAM': PROGRAM}, file=sys.stderr)
        sys.exit(1)

    # Parse options
    no_restart = False
    run_as_user = False
    stale_lock_cleanup = False
    quiet = False
    for opt, arg in opts:
        if opt in ('-h', '--help'):
            print(__doc__ % {'PROGRAM': PROGRAM})
            sys.exit(0)
        elif opt in ('-n', '--no-restart'):
            no_restart = True
        elif opt in ('-u', '--run-as-user'):
            run_as_user = True
        elif opt in ('-s', '--stale-lock-cleanup'):
            stale_lock_cleanup = True
        elif opt in ('-q', '--quiet'):
            quiet = True

    # Check command
    if not args:
        print('No command specified', file=sys.stderr)
        print(__doc__ % {'PROGRAM': PROGRAM}, file=sys.stderr)
        sys.exit(1)
    command = args[0]

    # Check if we're running as the right user
    if not run_as_user:
        try:
            mailman_uid = pwd.getpwnam(mm_cfg.MAILMAN_USER).pw_uid
            mailman_gid = grp.getgrnam(mm_cfg.MAILMAN_GROUP).gr_gid
            if os.getuid() == 0:
                # We're root, so change to the mailman user
                os.setgid(mailman_gid)
                os.setuid(mailman_uid)
            elif os.getuid() != mailman_uid or os.getgid() != mailman_gid:
                print('You must be root or the mailman user to run this script',
                      file=sys.stderr)
                sys.exit(1)
        except (KeyError, OSError) as e:
            print(f'Error checking user/group: {e}', file=sys.stderr)
            sys.exit(1)

    # Handle the command
    if command == 'start':
        # Check for stale lock
        if stale_lock_cleanup:
            pid, hostname, status = get_lock_data()
            if status == 0:  # Process not running
                try:
                    os.unlink(mm_cfg.PIDFILE)
                except OSError as e:
                    if e.errno != errno.ENOENT:
                        print(str(e), file=sys.stderr)
                        sys.exit(1)
        # Start the master daemon
        write_pidfile()
        lock = acquire_lock_or_exit()
        status = Status()
        status.runners = {}
        status.restarts = {}
        # Start all queue runners
        for qrname, qrclass in mm_cfg.QUEUE_RUNNERS:
            pid = start_runner(qrname, qrclass, status)
            if pid is None:
                print(f'Failed to start queue runner: {qrname}', file=sys.stderr)
                sys.exit(1)
            if not quiet:
                print(f'Started queue runner: {qrname}')
        # Main loop
        while True:
            try:
                # Check for dead children
                pid, status = os.waitpid(-1, os.WNOHANG)
                if pid > 0:
                    # A child died
                    for qrname, qrpid in list(status.runners.items()):
                        if qrpid == pid:
                            if not quiet:
                                print(f'Queue runner {qrname} died with status {status}')
                            del status.runners[qrname]
                            if not no_restart:
                                status.restarts[qrname] = status.restarts.get(qrname, 0) + 1
                                if status.restarts[qrname] <= MAX_RESTARTS:
                                    pid = start_runner(qrname, mm_cfg.QUEUE_RUNNERS[qrname], status)
                                    if pid is None:
                                        print(f'Failed to restart queue runner: {qrname}',
                                              file=sys.stderr)
                                    elif not quiet:
                                        print(f'Restarted queue runner: {qrname}')
                # Sleep for a while
                time.sleep(SNOOZE)
                # Refresh the lock
                lock.refresh()
            except KeyboardInterrupt:
                # Clean up and exit
                for pid in status.runners.values():
                    try:
                        os.kill(pid, signal.SIGTERM)
                    except OSError:
                        pass
                unlock_and_exit(0)
            except Exception as e:
                print(f'Error in main loop: {e}', file=sys.stderr)
                time.sleep(SNOOZE)
    elif command == 'stop':
        kill_watcher()
        unlock_and_exit(0)
    elif command == 'restart':
        kill_watcher(signal.SIGINT)
        unlock_and_exit(0)
    elif command == 'reopen':
        kill_watcher(signal.SIGHUP)
        unlock_and_exit(0)
    else:
        print(f'Unknown command: {command}', file=sys.stderr)
        print(__doc__ % {'PROGRAM': PROGRAM}, file=sys.stderr)
        sys.exit(1)

if __name__ == '__main__':
    main()
